# ASTRA OS — Docker Dev Environment
# Copy this file or use the root .env.example

# Database
POSTGRES_DB=astra
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_dev

# Redis
REDIS_PORT=6379

# API
DATABASE_URL=postgresql+asyncpg://astra:astra_dev@postgres:5432/astra
REDIS_URL=redis://redis:6379/0
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# AI
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
DEFAULT_AI_MODEL=meta/llama-3.1-8b-instruct

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Temporal
TEMPORAL_HOST=temporal:7233
TEMPORAL_TASK_QUEUE=astra
