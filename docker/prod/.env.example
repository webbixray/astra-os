# Production Environment Variables
# Copy this file to .env.prod and fill in your values
# DO NOT COMMIT .env.prod TO VERSION CONTROL

# ============================================================
# Database
# ============================================================
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=your_secure_redis_password_here

# ============================================================
# Security
# ============================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your_very_secure_secret_key_64_chars_min

# ============================================================
# Domain Configuration
# ============================================================
DOMAIN=your-domain.com

# ============================================================
# Optional: Observability
# ============================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================
# Optional: Supabase (if using Supabase features)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# Docker Image Tags (optional, defaults to latest)
# ============================================================
API_IMAGE_TAG=latest
WEB_IMAGE_TAG=latest