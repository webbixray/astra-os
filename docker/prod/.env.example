# ============================================================
# Astra OS - Production Environment Configuration
# Copy this file to .env and fill in all required values
# ============================================================

# ============================================================
# REQUIRED - Core Configuration
# ============================================================
# Generate with: openssl rand -base64 48
SECRET_KEY=

# Domain for production (e.g., app.astra-os.io)
DOMAIN=

# Database password (generate strong password)
POSTGRES_PASSWORD=

# Redis password (generate strong password)
REDIS_PASSWORD=

# ============================================================
# REQUIRED - AI Providers (at least one)
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_API_KEY=

# ============================================================
# REQUIRED - Authentication & User Management
# ============================================================
# Get from Supabase Dashboard > Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OPTIONAL - Observability
# ============================================================
# Get from Sentry.io project settings
SENTRY_DSN=

# OpenTelemetry endpoint (e.g., http://otel-collector:4318)
OTLP_ENDPOINT=

# ============================================================
# OPTIONAL - Advertising Platform Integrations
# ============================================================
# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# Meta (Facebook/Instagram)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ============================================================
# ADVANCED - Temporal Configuration
# ============================================================
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=astra
TEMPORAL_TASK_QUEUE=astra-tasks

# ============================================================
# ADVANCED - Feature Flags
# ============================================================
# Enable tenant subdomain routing (requires wildcard DNS)
TENANT_SUBDOMAIN_ENABLED=false
ROOT_DOMAIN=

# Content schedule worker tuning
CONTENT_SCHEDULE_POLL_INTERVAL=60
CONTENT_SCHEDULE_BATCH_SIZE=10

# ============================================================
# DO NOT MODIFY - Set by deployment system
# ============================================================
ENVIRONMENT=production
APP_VERSION=${APP_VERSION:-latest}