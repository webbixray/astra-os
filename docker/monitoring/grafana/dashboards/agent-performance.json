        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(agent_runs_total{success=\"true\"}[5m])) / sum(rate(agent_runs_total[5m]))",
