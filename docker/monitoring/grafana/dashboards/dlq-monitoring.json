        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (task_type, result) (rate(agent_task_retries_total[5m]))",
          "legendFormat": "{{task_type}} - {{result}}",
          "refId": "A"
        }
      ],
      "title": "Agent Task Retry Outcomes/sec",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Top 10 streams by DLQ depth",
