# ============================================================
# ASTRA OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=astra
POSTGRES_USER=astra
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379

# ── API ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://astra:change-me-in-production@postgres:5432/astra
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-64-char-string
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# ── Web ─────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── AI / NVIDIA NIM ────────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
DEFAULT_AI_MODEL=meta/llama-3.1-8b-instruct

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Temporal ────────────────────────────────────────────────
TEMPORAL_HOST=temporal:7233
TEMPORAL_TASK_QUEUE=astra

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@astra.local

# ── Ads Platforms ──────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_ACCESS_TOKEN=
META_APP_SECRET=
