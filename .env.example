# ============================================================
# ASTRA OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=astra
POSTGRES_USER=astra
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PORT=6379

# ── API ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://astra:change-me-in-production@postgres:5432/astra
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-64-char-string
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
TEMPORAL_HOST=temporal:7233

# ── Web ─────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── AI Providers ───────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_NIM_BASE_URL=

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Temporal ────────────────────────────────────────────────
TEMPORAL_TASK_QUEUE=astra

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@astra.local

# ── Ads Platforms ──────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ── Observability ──────────────────────────────────────────
SENTRY_DSN=
OTLP_ENDPOINT=

# ── Multi-tenancy ──────────────────────────────────────────
TENANT_SUBDOMAIN_ENABLED=false
ROOT_DOMAIN=

# ── Content Scheduler ──────────────────────────────────────
CONTENT_SCHEDULE_POLL_INTERVAL=60
CONTENT_SCHEDULE_BATCH_SIZE=10
