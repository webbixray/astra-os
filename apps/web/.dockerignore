# ============================================================
# Web Docker Ignore - Production exclusions
# ============================================================

# Git
.git
.gitignore

# Node.js
node_modules
.pnpm-store
.yarn
.pnp
.pnp.js
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
.next
out
dist
build
*.tsbuildinfo

# Testing
coverage
.nyc_output
test-results
playwright-report

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Documentation
*.md
!README.md

# Config (keep essential)
*.config.js
*.config.ts
!next.config.ts
!tailwind.config.ts
!postcss.config.mjs
!tsconfig.json
!vitest.config.ts
!playwright.config.ts

# Development
Dockerfile.dev
docker-compose.override.yml

# Turbo
.turbo

# Logs
logs
*.log

# Cache
.cache
.vercel

# TypeScript
*.tsbuildinfo