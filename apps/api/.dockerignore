# ============================================================
# API Docker Ignore - Production exclusions
# ============================================================

# Git
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
coverage
htmlcov
*.egg-info
dist
build
.venv
venv
.env
.env.*
pip-wheel-metadata

# Tests
tests/
test_*.py
*_test.py
conftest.py

# Documentation
docs
*.md
!README.md

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Local
.local
.override

# Development
Dockerfile.dev
Dockerfile.worker
docker-compose.override.yml
scripts/*.sh
scripts/*.py
!scripts/seed_db.py
!scripts/check-migrations.sh
!scripts/db-backup.sh
!scripts/db-manage.sh

# Alembic (keep versions but not pyc)
alembic/versions/*.pyc

# Config
*.toml
!pyproject.toml
!uv.lock
