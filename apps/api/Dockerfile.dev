FROM python:3.14-alpine

RUN addgroup -S astra && adduser -S astra -G astra

WORKDIR /app

RUN apk add --no-cache git curl

RUN pip install uv --no-cache-dir

COPY apps/api/pyproject.toml apps/api/uv.lock ./
COPY services/agent_orchestrator ./services/agent_orchestrator

RUN uv sync --no-cache
RUN uv pip install -e ./services/agent_orchestrator --no-deps

COPY apps/api/alembic.ini ./alembic.ini
COPY apps/api/alembic ./alembic

COPY . .

RUN chown -R astra:astra /app

RUN chmod +x scripts/ 2>/dev/null || true

USER astra

ENV PATH="/app/.venv/bin:$PATH"

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:8000/api/v1/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
